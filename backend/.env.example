PORT=4000
# Origin of the deployed frontend (GitHub Pages URL), e.g. https://yourname.github.io
CORS_ORIGIN=http://localhost:5173
# Generate with: npm run hash-password -- "your-password"
MASTER_PASSWORD_HASH=
# Any long random string
JWT_SECRET=
# 32-byte key, hex-encoded (64 hex chars). Generate with: openssl rand -hex 32
SERVER_SECRET=
DB_PATH=data/app.db
